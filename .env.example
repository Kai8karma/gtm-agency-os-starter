# GTM Agency OS — environment template
# Copy to .env (never commit) and fill in.
#
#   cp .env.example .env
#
# Every required variable is enforced at startup by gtmos/config.py.
# Missing required vars → clear error, no silent failure.

# ----- Required: LLM ----------------------------------------------------------

# Anthropic API key. Used for agent execution + judge.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Default agent model. Match CLAUDE.md effort guidance.
GTMOS_AGENT_MODEL=claude-sonnet-4-6
# Default judge model. Cheap + fast.
GTMOS_JUDGE_MODEL=claude-haiku-4-5

# ----- Required: repo paths ---------------------------------------------------

# Resolves at startup. Defaults to repo root if unset.
GTMOS_REPO_ROOT=

# ----- Required for Slack handler --------------------------------------------

# Slack bot token (xoxb-…). Scopes: chat:write, im:write, commands.
SLACK_BOT_TOKEN=
# Slack signing secret. Used for HMAC request verification.
# https://api.slack.com/authentication/verifying-requests-from-slack
SLACK_SIGNING_SECRET=
# Optional. Limits which workspace can invoke the bot.
SLACK_TEAM_ID=

# ----- Optional: connectors --------------------------------------------------

# HubSpot private-app token (CRM). Required only for HubSpot-backed routines.
HUBSPOT_PRIVATE_APP_TOKEN=
# Lemlist API key (sequencer). Required only for Lemlist-backed routines.
LEMLIST_API_KEY=
# Notion integration token (task store). Required only when GTMOS_TASK_STORE=notion.
NOTION_TOKEN=
NOTION_TASKS_DB_ID=

# ----- Optional: behavior tuning --------------------------------------------

# Task store backend: sqlite (default) or notion.
GTMOS_TASK_STORE=sqlite
# Sqlite path. Default: $GTMOS_REPO_ROOT/runs/.state/tasks.db
GTMOS_TASKS_DB=

# Max wall-clock seconds per agent run. Hard kill above this.
GTMOS_AGENT_TIMEOUT_S=300
# Max wall-clock seconds per judge run.
GTMOS_JUDGE_TIMEOUT_S=120

# Slack signature replay window (seconds). Default 300 (Slack recommendation).
SLACK_SIG_REPLAY_WINDOW_S=300

# Log level: DEBUG / INFO / WARNING / ERROR.
GTMOS_LOG_LEVEL=INFO
